# =============================================
# AutoCareX Backend Environment Variables
# =============================================
# Copy this file to .env and fill in all values before running the server.
# NEVER commit .env to version control.

# ---- Server ----
NODE_ENV=development
PORT=8000
HOST=0.0.0.0
APP_URL=https://autocarex.in

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autocarex
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_SSL=false

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Or full URL: REDIS_URL=redis://localhost:6379

# ---- JWT ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_64_bytes_hex_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_64_bytes_hex_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Twilio (OTP / SMS) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Optional: Twilio Verify (recommended for OTP)
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to 'true' to skip actual SMS in development
SKIP_SMS=true

# ---- Firebase (FCM Push Notifications) ----
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
# Alternative: pass entire service account JSON
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ---- AWS S3 ----
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
AWS_S3_BUCKET=autocarex-media
# Optional: CloudFront CDN URL
AWS_CDN_URL=https://cdn.autocarex.in

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://autocarex.in

# ---- Logging ----
LOG_DIR=./logs

# ---- Feature Flags ----
# Set to 'true' to skip SMS in development
SKIP_SMS=true

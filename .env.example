# ================================================================
# AutoCareX — Root Environment Template
# Copy to .env and fill all values before running docker-compose
# ================================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_DB=autocareX
POSTGRES_USER=autocareX
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://autocareX:CHANGE_ME@postgres:5432/autocareX

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ── App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1

# ── JWT / Auth ──────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET_HERE_USE_OPENSSL_RAND
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=CHANGE_ME_ANOTHER_64_CHAR_SECRET
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Admin Panel ─────────────────────────────────────────────
VITE_API_URL=https://api.autocareX.in/api/v1
VITE_SOCKET_URL=https://api.autocareX.in

# ── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=CHANGE_ME_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ── Firebase (Push Notifications) ───────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── AWS ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET
AWS_REGION=ap-south-1
AWS_S3_BUCKET=autocareX-uploads
AWS_CLOUDFRONT_URL=https://cdn.autocareX.in

# ── Twilio (SMS / OTP) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── SendGrid (Email) ─────────────────────────────────────────
SENDGRID_API_KEY=SG.CHANGE_ME_SENDGRID_KEY
EMAIL_FROM=noreply@autocareX.in
EMAIL_FROM_NAME=AutoCareX

# ── Google Maps ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=CHANGE_ME_GOOGLE_MAPS_KEY

# ── OpenAI (AI features) ────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_KEY

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=https://admin.autocareX.in,https://autocareX.in

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=https://CHANGE_ME@sentry.io/XXXXXXX

# ── Slack (Notifications) ───────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
SLACK_CHANNEL=#autocareX-alerts
